# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/docuquery
DATABASE_URL_SYNC=postgresql://postgres:postgres@db:5432/docuquery

# Redis
REDIS_URL=redis://redis:6379/0

# OpenAI
OPENAI_API_KEY=your-key-here

# JWT
JWT_SECRET_KEY=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=http://localhost:5173

# Application
APP_NAME=DocuQuery AI
APP_VERSION=1.0.0
LOG_LEVEL=INFO

# Chunking
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Embedding
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# LLM
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1000

# File Upload
MAX_FILE_SIZE_MB=20

# Rate Limiting
RATE_LIMIT_PER_MINUTE=20
